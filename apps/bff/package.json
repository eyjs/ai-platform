{
  "name": "@aip/bff",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx nest start --watch",
    "build": "npx nest build",
    "start": "node dist/main",
    "start:dev": "npx nest start --watch",
    "start:prod": "node dist/main",
    "lint": "npx eslint \"{src,test}/**/*.ts\"",
    "typecheck": "npx tsc --noEmit",
    "migration:run": "npx typeorm migration:run -d dist/config/database.config.js",
    "migration:revert": "npx typeorm migration:revert -d dist/config/database.config.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/typeorm": "^10.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "typeorm": "^0.3.20",
    "pg": "^8.13.1",
    "bcrypt": "^5.1.1",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "js-yaml": "^4.1.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.0",
    "@types/passport-jwt": "^4.0.1",
    "typescript": "^5.7.3",
    "eslint": "^9.22.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}
