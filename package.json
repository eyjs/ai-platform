{
  "name": "ai-platform",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace @aip/frontend",
    "build:frontend": "npm run build --workspace @aip/frontend",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
