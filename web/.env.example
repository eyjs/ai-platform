# FastAPI Backend
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000

# NestJS BFF
NEXT_PUBLIC_BFF_URL=http://localhost:3001

# BFF Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_platform

# JWT (must match FastAPI AIP_JWT_SECRET)
JWT_SECRET=your-jwt-secret-here

# BFF Port
BFF_PORT=3001

# Frontend Port
FRONTEND_PORT=3000
