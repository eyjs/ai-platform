# AI Platform 환경변수
# prefix: AIP_

# 프로바이더 모드: development | openai | gemini
AIP_PROVIDER_MODE=development

# PostgreSQL (벡터 DB + 캐시 + 큐 + 세션 통합)
AIP_DATABASE_URL=postgresql://aip:aip_dev@localhost:5432/ai_platform

# Ollama (development 모드)
AIP_OLLAMA_HOST=http://localhost:11434
AIP_ROUTER_MODEL=qwen3:8b
AIP_MAIN_MODEL=gemma2:9b

# OpenAI (openai 모드)
# AIP_OPENAI_API_KEY=sk-...
# AIP_PROD_LLM_MODEL=gpt-4o-mini
# AIP_PROD_EMBEDDING_MODEL=text-embedding-3-small

# Gemini (gemini 모드)
# AIP_GEMINI_API_KEY=...

# GPU 서버 URL (선택 - 호스트에서 실행 시)
# AIP_EMBEDDING_SERVER_URL=http://host.docker.internal:8103
# AIP_RERANKER_SERVER_URL=http://host.docker.internal:8102

# 응답 정책: strict(문서 없으면 거절) | balanced(LLM 폴백)
AIP_RESPONSE_POLICY=strict

# 청킹
AIP_CHUNK_SIZE=1000
AIP_CHUNK_OVERLAP=200

# JWT 인증 (선택)
# AIP_JWT_SECRET=your-secret-key

# 서버
AIP_HOST=0.0.0.0
AIP_PORT=8000
