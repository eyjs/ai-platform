# AI Platform 환경변수
# prefix: AIP_

# 프로바이더 모드: development | openai | anthropic
AIP_PROVIDER_MODE=development

# PostgreSQL (벡터 DB + 캐시 + 큐 + 세션 통합)
AIP_DATABASE_URL=postgresql://aip:aip_dev@localhost:5434/ai_platform

# MLX GPU 서버 URL (호스트에서 실행 — development 모드 기본)
AIP_EMBEDDING_SERVER_URL=http://localhost:8103
AIP_RERANKER_SERVER_URL=http://localhost:8102
AIP_ROUTER_LLM_SERVER_URL=http://localhost:8105
AIP_MAIN_LLM_SERVER_URL=http://localhost:8104

# OpenAI (openai 모드)
# AIP_OPENAI_API_KEY=sk-...
# AIP_PROD_LLM_MODEL=gpt-4o-mini
# AIP_PROD_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic Claude (anthropic 모드) — 기본 모델 Haiku(최저가). 설치: pip install -e "apps/api[anthropic]"
# 전환: AIP_PROVIDER_MODE=anthropic + 아래 키 입력 + 로컬 LLM 서버 URL 주석 처리
# AIP_ANTHROPIC_API_KEY=sk-ant-...
# AIP_ANTHROPIC_MAIN_MODEL=claude-haiku-4-5
# AIP_ANTHROPIC_ROUTER_MODEL=claude-haiku-4-5

# Ollama 폴백 (MLX 서버 미실행 시)
# AIP_OLLAMA_HOST=http://localhost:11434
# AIP_ROUTER_MODEL=qwen3:8b
# AIP_MAIN_MODEL=gemma2:9b

# 문서 파서: text(기본 텍스트 추출) | llamaparse(Vision API)
AIP_PARSER_PROVIDER=text
# AIP_LLAMAPARSE_API_KEY=llx-...

# 응답 정책: strict(문서 없으면 거절) | balanced(LLM 폴백)
AIP_RESPONSE_POLICY=strict

# 청킹
AIP_CHUNK_SIZE=1000
AIP_CHUNK_OVERLAP=200

# KMS 연동 (도메인 SSOT — Docker 내부 통신)
# AIP_KMS_API_URL=http://kms-api:3000/api
# AIP_KMS_INTERNAL_KEY=change-me-shared-secret

# 로깅
AIP_LOG_FORMAT=json
AIP_LOG_LEVEL=INFO

# JWT 인증 (선택)
# AIP_JWT_SECRET=your-secret-key

# JWT 비대칭 검증 (D17). bff가 개인키로 RS256 서명, api는 공개키로 검증만.
# 키 생성: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem
#          openssl pkey -in jwt_private.pem -pubout -out jwt_public.pem
#   - api/worker: 공개키만 (개인키 두지 않음)
#   - bff: 개인키(서명) + 공개키(자체 검증)
# AIP_JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
# AIP_JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem   # bff 전용
# 과도기: RS256 전환 후에도 기존 HS256 토큰 검증 허용(만료로 자연소멸).
# 전환 검증 완료 후 false로 잠가 대칭키 퇴역.
# AIP_JWT_HS256_FALLBACK=true

# 프로필 인가 deny-by-default (A1). true면 빈 allowed_profiles/테넌트 매핑 = 전체 거부.
# 명시적 전체 허용은 와일드카드 "*"로. 전환 전 반드시 백필 실행:
#   python -m scripts.backfill_profile_authz --apply
# AIP_PROFILE_AUTH_STRICT=false

# API 키 종류 (B4). publishable=위젯(브라우저 노출): 오리진 필수·보안등급 PUBLIC 한정·
# 읽기(VIEWER) 전용·쿼터 상한 강제. secret=서버 전용(기본): 기존 권한 유지.
# 아래는 publishable 키 발급 시 허용되는 분당 쿼터 상한.
# AIP_PUBLISHABLE_RATE_LIMIT_MAX=120

# 레이트리밋 유휴 버킷 정리 TTL(초, B5). 복합키(API키:세션)로 버킷이 늘어나므로
# 이 시간 이상 미사용된 버킷을 주기적으로 삭제(만석 복귀라 안전).
# AIP_RATE_LIMIT_IDLE_TTL=3600

# 테넌트 격리 기본 테넌트 (A2/4a). tenant_id 미지정 쓰기를 이 값으로 스탬핑.
# 마이그레이션 019의 백필 값('default')과 일치해야 한다.
# AIP_DEFAULT_TENANT_ID=default

# RLS 심층방어 (A2/4c). true면 요청마다 SET ROLE aip_app + app.current_tenant GUC로
# DB가 테넌트 행만 보이게 강제(앱 필터 누락도 차단). 마이그레이션 020 적용 필수.
# 기본 false(superuser 접속 = RLS 우회, 동작 무변).
# AIP_RLS_ENABLED=false
# AIP_RLS_ROLE=aip_app

# DocForge (PDF 파싱 서버)
AIP_DOCFORGE_URL=http://localhost:5051
AIP_DOCFORGE_INTERNAL_KEY=change-me-docforge-secret

# 서버
AIP_HOST=0.0.0.0
AIP_PORT=8000
